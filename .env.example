DATABASE_URL="postgresql://postgres:[YOUR_URL_ENCODED_PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Razorpay — get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxx"

# Cloudflare R2 — for photo + audio storage (free tier: 10 GB / 1M writes / month)
# Setup: https://dash.cloudflare.com → R2 → Create bucket → API tokens
# Enable "Public Access" on the bucket to get NEXT_PUBLIC_R2_PUBLIC_URL
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="invite-media"
NEXT_PUBLIC_R2_PUBLIC_URL="https://pub-xxxxxxxxxxxx.r2.dev"

# If your database password contains special characters, encode them for URLs.
# Example: @ becomes %40
